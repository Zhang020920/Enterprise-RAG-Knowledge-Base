# OpenAI / 通义千问 API 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 文档切分配置
chunk_size=500
chunk_overlap=50
separators=["\n\n", "\n", "。", "！", "？"]

# Hugging Face 配置（可选，用于下载模型）
HF_TOKEN=your_hf_token_here
HF_ENDPOINT=https://hf-mirror.com

# 向量数据库与BM25索引存储路径
db_path=vector_db
store_path=data/doc_store
bm25_path=vector_db/bm25_index.pkl
cache_file=vector_db/processed_hashes.txt

# Redis 配置（缓存）
REDIS_HOST=redis-server
REDIS_PORT=6379
REDIS_PASSWORD=          # 如果没有密码则留空，不要写 None 字符串
ENABLE_CACHE=True

# 缓存版本（文档重建索引或提示词变更后递增，触发自动失效）
INDEX_VERSION=v1
PROMPT_VERSION=v1
CACHE_KEY_PREFIX=rag_cache

# Streamlit display page backend URL
API_BASE_URL=http://localhost:8000

# Retrieval tuning
VECTOR_TOP_K=12
BM25_TOP_K=12
RERANK_TOP_N=8
RERANK_MIN_SCORE=0.2
RERANK_SCORE_DROP=0.2
MAX_FUSED_DOCS=6

# Layered cache TTLs, in seconds
REWRITE_CACHE_TTL=3600
RETRIEVAL_CACHE_TTL=1800
ANSWER_CACHE_TTL=3600

# Parent-child chunking
PARENT_CHUNK_SIZE=1000
PARENT_CHUNK_OVERLAP=120
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=60

# Retrieval quality features
ENABLE_INTENT_FILTER=True
ENABLE_HYDE=True
HYDE_CACHE_TTL=3600
ORIGINAL_QUERY_WEIGHT=1.25
REWRITTEN_QUERY_WEIGHT=1.0
HYDE_QUERY_WEIGHT=0.75
